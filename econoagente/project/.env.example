# Copiar como .env para desarrollo local.
# En Streamlit Cloud, poner estos valores en App > Settings > Secrets.

APP_MODE=demo
# APP_MODE=production

# Opción recomendada: conexión Postgres/Supabase read-only.
# Formato típico:
# postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
SUPABASE_DATABASE_URL=

# Seguridad del agente
AGENT_ALLOWED_SCHEMAS=gold,mart,public
AGENT_MAX_ROWS=500
AGENT_QUERY_TIMEOUT_SECONDS=20

# Auditoría local
AGENT_LOG_PATH=logs/query_audit.csv
